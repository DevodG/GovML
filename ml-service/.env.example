# GovChain ML Service Configuration

# API Configuration
APP_NAME=GovChain ML Service
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# NVIDIA NIM Configuration (FREE TIER)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_MAX_TOKENS=2048
NVIDIA_TEMPERATURE=0.7

# Model Configuration
MODEL_CACHE_DIR=./models
MODEL_RETRAIN_INTERVAL=86400
BID_SCORING_MODEL=ensemble
FRAUD_DETECTION_MODEL=isolation_forest
ANOMALY_THRESHOLD=0.85

# Scoring Weights
WEIGHT_BID_AMOUNT=0.40
WEIGHT_RATING=0.45
WEIGHT_COMPLETION_RATE=0.10
WEIGHT_NEWCOMER_BOOST=0.05

# Fraud Detection Thresholds
FRAUD_THRESHOLD_OVERPRICING=1.30
FRAUD_THRESHOLD_UNDERPRICING=0.50
FRAUD_THRESHOLD_VELOCITY=7

# Caching Configuration
CACHE_ENABLED=true
CACHE_TTL=3600
REDIS_URL=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/ml_service.log

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090

# Security
API_KEY_REQUIRED=false
API_KEY=

# Demo Mode
DEMO_MODE=false
DEMO_TIMER_MINUTES=2
